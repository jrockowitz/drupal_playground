<?php

/**
 * @file
 * Report and CSV export/import for entity type, bundle, and field label metadata.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\entity_labels\Hook\EntityLabelsHooks;

/**
 * Implements hook_help().
 */
#[LegacyHook]
function entity_labels_help(string $route_name, RouteMatchInterface $route_match): string {
  return \Drupal::service(EntityLabelsHooks::class)->help($route_name, $route_match);
}
