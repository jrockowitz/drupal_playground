#!/bin/bash

set -euo pipefail

## Description: Install Drupal, optionally with one or more presets.
## Usage: install [preset...]
## Example: ddev install\nddev install ai\nddev install eca\nddev install elastic\nddev install schemadotorg\nddev install translation\nddev install trials\nddev install trials-setup\nddev install trials-elastic\nddev install trials-milvus\nddev install trials-milvus trials-chat
## ProjectTypes: drupal,drupal11

uli_path="/"

# Delete Elasticsearch indexes that can survive across repeated local installs.
# The Search API Elasticsearch backend can reuse stale mappings unless the
# physical index is removed before the recipe recreates the Drupal index.
reset_elasticsearch_index() {
  local index_name="$1"

  curl -fsS -X DELETE "http://elasticsearch:9200/${index_name}" >/dev/null 2>&1 || true

  if [ -n "${DDEV_SITENAME:-}" ]; then
    curl -fsS -X DELETE "http://elasticsearch:9200/${DDEV_SITENAME}_${index_name}" >/dev/null 2>&1 || true
  fi
}

drush site:install standard \
  --db-url=mysql://db:db@db/db \
  --site-name="Drupal Playground" \
  --account-name=admin \
  --account-pass=admin \
  --account-mail=admin@example.com \
  --yes

# Some local installs end up with core.extension missing its theme map even
# though system.theme is present. Normalize it before enabling more modules so
# post-update listeners do not crash during module installation.
drush php:eval '
$core_extension = \Drupal::service("config.factory")->getEditable("core.extension");
if ($core_extension->get("theme") === NULL) {
  $system_theme = \Drupal::config("system.theme");
  $themes = [];
  foreach (["default", "admin"] as $theme_type) {
    $theme_name = $system_theme->get($theme_type);
    if (is_string($theme_name) && $theme_name !== "") {
      $themes[$theme_name] = 0;
    }
  }
  if ($themes !== []) {
    $core_extension->set("theme", $themes)->save();
  }
}
'

drush recipe ../recipes/drupal_playground_base
drush recipe ../recipes/drupal_playground_admin
drush recipe ../recipes/drupal_playground_devel
drush recipe ../recipes/drupal_playground_ai
drush cr;

# Uninstall the toolbar module, which can't be done via a recipe.
drush pm:uninstall toolbar

for PRESET in "$@"; do
  if [ "$PRESET" = "ai" ]; then

    echo "Applying AI recipe..."
    drush recipe ../recipes/drupal_playground_ai_chat
    drush recipe ../recipes/drupal_playground_ai_ckeditor
    drush recipe ../recipes/drupal_playground_ai_content_suggestions
    drush recipe ../recipes/drupal_playground_ai_devel
    drush recipe ../recipes/drupal_playground_ai_automators
    drush recipe ../recipes/drupal_playground_ai_ckeditor_explain

    echo "Applying AI Schema.org JSON-LD recipe..."
    drush recipe ../recipes/drupal_playground_ai_schemadotorg_jsonld
    uli_path="/admin/config/ai"

  elif [ "$PRESET" = "schemadotorg" ]; then

    echo "Applying Schema.org Blueprints recipe..."
    drush recipe ../recipes/drupal_playground_schemadotorg
    uli_path="/admin/config/schemadotorg"

  elif [ "$PRESET" = "eca" ]; then

    echo "Applying ECA Starterkit recipe..."
    drush recipe ../recipes/drupal_playground_eca
    uli_path="/admin/config/workflow/eca"

  elif [ "$PRESET" = "elastic" ]; then

    reset_elasticsearch_index "drupal_playground_elasticsearch"
    echo "Applying Elasticsearch recipe..."
    drush recipe ../recipes/drupal_playground_elasticsearch
    uli_path="/elasticsearch"

  elif [ "$PRESET" = "translation" ]; then

    echo "Applying translation recipe..."
    drush recipe ../recipes/drupal_playground_translation
    drush locale-check
    drush locale-update

  elif [ "$PRESET" = "modules" ]; then

    drush en -y telephone_filter entity_labels

  elif [ "$PRESET" = "trials" ]; then

    echo "Installing ClinicalTrials.gov module..."
    drush en -y readonly_field_widget clinical_trials_gov clinical_trials_gov_report
    uli_path="/admin/config/services/clinical-trials-gov"

  elif [ "$PRESET" = "trials-setup" ]; then

    echo "Applying ClinicalTrials.gov setup recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_setup
    drush migrate:import clinical_trials_gov --limit=10
    uli_path="/admin/config/services/clinical-trials-gov"

  elif [ "$PRESET" = "trials-elastic" ]; then

    reset_elasticsearch_index "trials_elasticsearch"
    echo "Applying ClinicalTrials.gov setup recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_setup
    echo "Applying Clinical Trials Elasticsearch recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_elastic
    echo "Applying Clinical Trials Elasticsearch autocomplete recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_elastic_autocomplete
    echo "Importing ClinicalTrials.gov studies..."
    drush migrate:import clinical_trials_gov --limit=10
    echo "Indexing ClinicalTrials.gov studies in Elasticsearch..."
    drush search-api:clear trials_elasticsearch -y
    drush search-api:index trials_elasticsearch -y;
    uli_path="/trials"

  elif [ "$PRESET" = "trials-milvus" ]; then

    echo "Applying AI recipe..."
    drush recipe ../recipes/drupal_playground_ai
    drush recipe ../recipes/drupal_playground_ai_devel
    echo "Applying ClinicalTrials.gov setup recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_setup
    echo "Applying Clinical Trials Milvus recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_milvus
    echo "Indexing ClinicalTrials.gov studies in Milvus..."
    drush search-api:clear trials_milvus -y
    drush search-api:index trials_milvus -y;
    uli_path="/trials"

  elif [ "$PRESET" = "trials-chat" ]; then

    echo "Applying Clinical Trials chat recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_milvus_chat
    uli_path="/trials"

  fi
done

drush cr

echo ""
echo "Installation complete. One-time login URL:"
drush uli "$uli_path"
