#!/bin/bash

## Description: Install Drupal, optionally with one or more presets or all presets
## Usage: install [preset...]
## Example: ddev install\nddev install ai\nddev install eca\nddev install elastic\nddev install schemadotorg\nddev install translation\nddev install all
## ProjectTypes: drupal,drupal11

if [ "$#" -gt 1 ]; then
  for PRESET in "$@"; do
    if [ "$PRESET" = "all" ]; then
      echo "The all preset must be used by itself."
      exit 1
    fi
  done
fi

if [ "$1" = "all" ]; then
  set -- ai schemadotorg eca translation
fi

drush site:install standard \
  --db-url=mysql://db:db@db/db \
  --site-name="Drupal Playground" \
  --account-name=admin \
  --account-pass=admin \
  --account-mail=admin@example.com \
  --yes

drush recipe ../recipes/drupal_playground_base
drush recipe ../recipes/drupal_playground_admin
drush recipe ../recipes/drupal_playground_devel
drush cr;

# Uninstall the toolbar module, which can't be done via a recipe.
drush pm:uninstall toolbar

for PRESET in "$@"; do
  if [ "$PRESET" = "ai" ]; then
    echo "Applying AI recipe..."
    drush recipe ../recipes/drupal_playground_ai
    drush recipe ../recipes/drupal_playground_ai_chat
    drush recipe ../recipes/drupal_playground_ai_ckeditor
    drush recipe ../recipes/drupal_playground_ai_content_suggestions
    drush recipe ../recipes/drupal_playground_ai_devel
    drush recipe ../recipes/drupal_playground_ai_automators
    drush recipe ../recipes/drupal_playground_ai_ckeditor_explain

    echo "Applying AI Schema.org JSON-LD recipe..."
    drush recipe ../recipes/drupal_playground_ai_schemadotorg_jsonld
  elif [ "$PRESET" = "schemadotorg" ]; then
    echo "Applying Schema.org Blueprints recipe..."
    drush recipe ../recipes/drupal_playground_schemadotorg
  elif [ "$PRESET" = "eca" ]; then
    echo "Applying ECA Starterkit recipe..."
    drush recipe ../recipes/drupal_playground_eca
  elif [ "$PRESET" = "elastic" ]; then
    echo "Applying Elasticsearch recipe..."
    drush recipe ../recipes/drupal_playground_elasticsearch
    echo "Indexing Elasticsearch demo content..."
    drush search-api:index drupal_playground_articles
  elif [ "$PRESET" = "translation" ]; then
    echo "Applying translation recipe..."
    drush recipe ../recipes/drupal_playground_translation
    drush locale-check
    drush locale-update
  elif [ "$PRESET" = "modules" ]; then
    drush en -y telephone_filter entity_labels
  elif [ "$PRESET" = "trials" ]; then
    echo "Installing ClinicalTrials.gov module..."
    drush en -y readonly_field_widget clinical_trials_gov clinical_trials_gov_report
    # drush config:set -y clinical_trials_gov.settings query 'query.term=Memorial%20Sloan%20Kettering&filter.overallStatus=RECRUITING'
  fi
done

drush cr

echo ""
echo "Installation complete. One-time login URL:"
drush uli
