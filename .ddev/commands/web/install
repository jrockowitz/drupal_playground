#!/bin/bash
# cspell:ignore pipefail milvus esac

set -euo pipefail

## Description: Install Drupal, optionally with one or more presets.
## Usage: install [preset...]
## Example: ddev install\nddev install ai\nddev install openai\nddev install anthropic\nddev install gemini\nddev install anthropic ai\nddev install eca\nddev install elastic\nddev install schemadotorg\nddev install translation\nddev install webform-setup\nddev install webform-test\nddev install trials\nddev install trials-fields\nddev install trials-fields-setup\nddev install trials-fields-setup --limit=50 --query="query.cond=Cancer&query.locn=New%20York&filter.overallStatus=RECRUITING%7CNOT_YET_RECRUITING"\nddev install trials-data-setup trials-data-elastic --limit=50 --query="query.cond=Cancer&query.locn=New%20York&filter.overallStatus=RECRUITING%7CNOT_YET_RECRUITING"\nddev install trials-fields-elastic\nddev install trials-fields-milvus\nddev install trials-data-setup\nddev install trials-data-elastic\nddev install trials-data-milvus\nddev install trials-data-elastic trials-data-milvus
## ProjectTypes: drupal,drupal11

uli_path="/"
LIMIT="10"
QUERY=""
PRESETS=()

apply_clinical_trials_query_override() {
  if [ -z "$QUERY" ]; then
    return
  fi

  echo "Applying ClinicalTrials.gov query override..."
  drush clinical-trials-gov:setup "$QUERY"
}

# Parse --options for limit and query.
for argument in "$@"; do
  case "$argument" in
    --limit=*)
      LIMIT="${argument#*=}"
      ;;

    --query=*)
      QUERY="${argument#*=}"
      ;;

    *)
      PRESETS+=("$argument")
      ;;
  esac
done

# Expand the trials-data convenience preset into the default data-search flow.
if [ "${#PRESETS[@]}" -eq 1 ] && [ "${PRESETS[0]}" = "trials-data" ]; then
  PRESETS=("trials-data-setup" "trials-data-elastic" "trials-data-milvus")
fi

# Expand the trials-fields convenience preset into the field-based flow.
if [ "${#PRESETS[@]}" -eq 1 ] && [ "${PRESETS[0]}" = "trials-fields" ]; then
  PRESETS=("trials-fields-setup" "trials-fields-elastic" "trials-fields-milvus")
fi

drush sql:drop -y

drush site:install standard \
  --db-url=mysql://db:db@db/db \
  --site-name="Drupal Playground" \
  --account-name=admin \
  --account-pass=admin \
  --account-mail=admin@example.com \
  --yes

drush recipe ../recipes/drupal_playground_base
drush recipe ../recipes/drupal_playground_admin
drush recipe ../recipes/drupal_playground_devel
drush recipe ../recipes/drupal_playground_ai
drush recipe ../recipes/drupal_playground_ai_devel

drush cr;

# Uninstall the toolbar module, which can't be done via a recipe.
drush pm:uninstall toolbar

# Set AI provider configuration before applying other presets.
for PRESET in "${PRESETS[@]}"; do
  if [ "$PRESET" = "openai" ] || [ "$PRESET" = "anthropic" ] || [ "$PRESET" = "gemini" ]; then
    echo "Applying ${PRESET} provider recipe..."
    if [ "$PRESET" = "anthropic" ]; then
      drush recipe ../recipes/drupal_playground_ai_provider_anthropic
    elif [ "$PRESET" = "gemini" ]; then
      drush recipe ../recipes/drupal_playground_ai_provider_gemini
    else
      drush recipe ../recipes/drupal_playground_ai_provider_openai
    fi
  fi
done

# Apply presets.
for PRESET in "${PRESETS[@]}"; do
  if [ "$PRESET" = "ai" ]; then

    echo "Applying AI recipe..."
    drush recipe ../recipes/drupal_playground_ai_chat
    drush recipe ../recipes/drupal_playground_ai_ckeditor
    drush recipe ../recipes/drupal_playground_ai_content_suggestions
    drush recipe ../recipes/drupal_playground_ai_devel
    drush recipe ../recipes/drupal_playground_ai_automators
    drush recipe ../recipes/drupal_playground_ai_ckeditor_explain

    echo "Applying AI Schema.org JSON-LD recipe..."
    drush recipe ../recipes/drupal_playground_ai_schemadotorg_jsonld
    uli_path="/admin/config/ai"

  elif [ "$PRESET" = "schemadotorg" ]; then

    echo "Applying Schema.org Blueprints recipe..."
    drush recipe ../recipes/drupal_playground_schemadotorg
    uli_path="/admin/config/schemadotorg"

  elif [ "$PRESET" = "eca" ]; then

    echo "Applying ECA Starterkit recipe..."
    drush recipe ../recipes/drupal_playground_eca
    uli_path="/admin/config/workflow/eca"

  elif [ "$PRESET" = "elastic" ]; then

    echo "Resetting ClinicalTrials.gov studies in Elasticsearch..."
    curl -fsS -X DELETE "http://elasticsearch:9200/drupal_playground_elasticsearch" >/dev/null 2>&1 || true
    echo "Applying Elasticsearch recipe..."
    drush recipe ../recipes/drupal_playground_elasticsearch
    uli_path="/elasticsearch"

  elif [ "$PRESET" = "translation" ]; then

    echo "Applying translation recipe..."
    drush recipe ../recipes/drupal_playground_translation
    drush locale-check
    drush locale-update

  elif [ "$PRESET" = "webform-setup" ] || [ "$PRESET" = "webform" ]; then

    echo "Applying Webform setup recipe..."
    drush recipe ../recipes/drupal_playground_webform_setup
    uli_path="/admin/structure/webform"

  elif [ "$PRESET" = "webform-test" ]; then

    echo "Applying Webform setup recipe..."
    drush recipe ../recipes/drupal_playground_webform_setup
    echo "Applying Webform test recipe..."
    drush recipe ../recipes/drupal_playground_webform_test
    echo "Enabling Webform node multiple and submissions test modules..."
    drush en -y webform_node_test_multiple webform_test_submissions
    uli_path="/admin/structure/webform"

  elif [ "$PRESET" = "modules" ]; then

    drush en -y telephone_filter entity_labels

  elif [ "$PRESET" = "trials" ]; then

    echo "Installing ClinicalTrials.gov module..."
    drush en -y readonly_field_widget clinical_trials_gov clinical_trials_gov_report
    uli_path="/admin/config/services/clinical-trials-gov"

  elif [ "$PRESET" = "trials-fields-setup" ]; then

    echo "Applying ClinicalTrials.gov fields setup recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_fields_setup
    apply_clinical_trials_query_override
    echo "Importing ClinicalTrials.gov studies..."
    drush migrate:import clinical_trials_gov --limit="$LIMIT"
    echo "Running AI Automator queue..."
    drush queue:run ai_automator_field_modifier
    uli_path="/admin/config/services/clinical-trials-gov"

  elif [ "$PRESET" = "trials-fields-elastic" ]; then

    echo "Applying ClinicalTrials.gov fields Elasticsearch recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_fields_elastic
    apply_clinical_trials_query_override
    echo "Resetting ClinicalTrials.gov studies in Elasticsearch..."
    curl -fsS -X DELETE "http://elasticsearch:9200/trials_elasticsearch" >/dev/null 2>&1 || true
    echo "Indexing ClinicalTrials.gov studies in Elasticsearch..."
    drush search-api:clear trials_elasticsearch -y
    drush search-api:index trials_elasticsearch -y;
    uli_path="/trials"

  elif [ "$PRESET" = "trials-fields-milvus" ]; then

    echo "Applying ClinicalTrials.gov fields Milvus recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_fields_milvus
    apply_clinical_trials_query_override
    echo "Indexing ClinicalTrials.gov studies in Milvus..."
    drush search-api:clear trials_milvus -y
    drush search-api:index trials_milvus -y;
    uli_path="/trials"

  elif [ "$PRESET" = "trials-data-setup" ]; then

    echo "Applying ClinicalTrials.gov data setup recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_data_setup
    apply_clinical_trials_query_override
    echo "Importing ClinicalTrials.gov studies..."
    drush migrate:import clinical_trials_gov --limit="$LIMIT"
    uli_path="/admin/config/services/clinical-trials-gov"

  elif [ "$PRESET" = "trials-data-elastic" ]; then

    echo "Applying ClinicalTrials.gov data Elasticsearch recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_data_elastic
    apply_clinical_trials_query_override
    echo "Importing ClinicalTrials.gov studies..."
    drush migrate:import clinical_trials_gov --limit="$LIMIT"
    echo "Resetting ClinicalTrials.gov studies in Elasticsearch..."
    curl -fsS -X DELETE "http://elasticsearch:9200/trials_elasticsearch" >/dev/null 2>&1 || true
    echo "Indexing ClinicalTrials.gov studies in Elasticsearch..."
    drush search-api:clear trials_elasticsearch -y
    drush search-api:index trials_elasticsearch -y;
    uli_path="/trials"

  elif [ "$PRESET" = "trials-data-milvus" ]; then

    echo "Applying ClinicalTrials.gov data Milvus recipe..."
    drush recipe ../recipes/clinical_trials_gov_recipe_data_milvus
    apply_clinical_trials_query_override
    echo "Indexing ClinicalTrials.gov studies in Milvus..."
    drush search-api:clear trials_milvus -y
    drush search-api:index trials_milvus -y;
    uli_path="/trials"

  fi
done

drush cr

echo ""
echo "Installation complete. One-time login URL:"
drush uli "$uli_path"
