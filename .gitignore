# Recommended .gitignore for Drupal 10/11 Composer-managed projects
#
# References:
#   - https://github.com/github/gitignore/blob/main/Drupal.gitignore
#   - https://www.drupal.org/project/drupal/issues/3082958
#   - https://git.drupalcode.org/project/drupal (example.gitignore)
#   - https://github.com/acquia/drupal-recommended-project

# =============================================================================
# Composer dependencies
# =============================================================================
# Ignore the root vendor directory. Do NOT ignore vendor directories inside
# contrib or custom modules/themes (e.g. core/assets/vendor).
/vendor/

# =============================================================================
# Drupal core and contrib (managed by Composer)
# =============================================================================
.editorconfig
.gitattributes
/recipes/ai_*
/recipes/drupal_cms_*
/recipes/README.txt
/web/.csslintrc
/web/.eslintignore
/web/.eslintrc.json
/web/.ht.router.php
/web/.htaccess
/web/INSTALL.txt
/web/README.md
/web/autoload.php
/web/core/
/web/example.gitignore
/web/index.php
/web/libraries/
/web/modules/README.txt
/web/modules/contrib/
/web/profiles/README.txt
/web/profiles/contrib/
/web/robots.txt
/web/themes/README.txt
/web/themes/contrib/
/web/update.php
/web/web.config

# =============================================================================
# Configuration files that may contain sensitive information
# =============================================================================
/web/sites/README.txt
/web/sites/*settings*.php
/web/sites/*sites*.php
/web/sites/*services*.yml
/web/sites/*/*settings*.php
/web/sites/*/*services*.yml

# =============================================================================
# User-generated content
# =============================================================================
/web/sites/*/files/
/web/sites/*/public/
/web/sites/*/private/
/web/sites/*/files-public/
/web/sites/*/files-private/
/keys/

# =============================================================================
# Development and testing
# =============================================================================
/web/sites/development.services.yml
/web/sites/simpletest/

# =============================================================================
# IDE and editor files
# =============================================================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
nbproject/

# =============================================================================
# OS-generated files
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.directory

# =============================================================================
# Node / frontend build tools (if applicable)
# =============================================================================
node_modules/
npm-debug.log
yarn-error.log

# =============================================================================
# Agents / Claude skills
# =============================================================================
.agents/skills/
!.agents/skills/drupalorg-project-clone
!.agents/skills/drupalorg-project-logo-prompt
!.agents/skills/drupalorg-project-page
!.agents/skills/drupalorg-projects-clone
!.agents/skills/install

# =============================================================================
# Configuration
# =============================================================================
/config/sync

# =============================================================================
# Sandbox
# =============================================================================

# /web/modules/sandbox/
/web/modules/sandbox/eca_report
/web/modules/sandbox/entity_labels
/web/modules/sandbox/field_data
/web/modules/sandbox/local_tasks_more
/web/modules/sandbox/menu_export_csv
/web/modules/sandbox/plugin_report
/web/modules/sandbox/schemadotorg
/web/modules/sandbox/schemadotorg_experimental
/web/modules/sandbox/webform
/web/modules/sandbox/webform_confirmation_file
/web/modules/sandbox/webform_javascript_setting
/web/modules/sandbox/webform_no_submissions
/web/modules/sandbox/webform_payment_element
/web/modules/sandbox/webform_views


# =============================================================================
# Recipes
# =============================================================================
/recipes/eca_starterkit
/recipes/schemadotorg_recipes

# =============================================================================
# Database backup
# =============================================================================
/db.sql
